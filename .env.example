# Copie este arquivo para .env e preencha os valores

# Obtenha no painel do Neon.tech em: Project > Connection Details > Connection string
DATABASE_URL=postgresql://usuario:senha@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Gere uma chave segura com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-dev-only-key-change-in-production

DEBUG=True
ALLOWED_HOSTS=*
